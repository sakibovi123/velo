PORT=3001
NODE_ENV=development

# Must match SECRET_KEY in Django settings — used to verify agent JWTs
JWT_SECRET=your-django-secret-key-here

# Internal URL of the Django backend (never exposed publicly)
DJANGO_INTERNAL_URL=http://localhost:8000

# Redis — used for Socket.io adapter and API key caching
REDIS_URL=redis://localhost:6379

# TTL (seconds) for caching a validated API key in Redis
API_KEY_CACHE_TTL=300

# Shared secret for Node → Django internal API calls.
# Must match INTERNAL_API_SECRET in backend-django/.env
INTERNAL_API_SECRET=change-me-to-a-long-random-string
